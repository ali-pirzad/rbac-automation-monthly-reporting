{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "logicAppName": {
            "type": "string",
            "defaultValue": "la-rbac-changes-report"
        },
        "location": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]"
        }
    },
    "resources": [
        {
            "type": "Microsoft.Logic/workflows/triggers",
            "apiVersion": "2019-05-01",
            "name": "[concat(parameters('logicAppName'), '/manual')]",
            "properties": {
                "type": "Request",
                "kind": "Http",
                "inputs": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "lookbackDays": {
                                "type": "integer",
                                "description": "Override lookback period in days"
                            }
                        }
                    }
                }
            }
        }
    ],
    "outputs": {
        "triggerUrl": {
            "type": "string",
            "value": "[listCallbackUrl(resourceId('Microsoft.Logic/workflows/triggers', parameters('logicAppName'), 'manual'), '2019-05-01').value]"
        }
    }
}
